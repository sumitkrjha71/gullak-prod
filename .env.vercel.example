# ──────────────────────────────────────────────────────────────────────────────
# Vercel env-var paste sheet for `gullak-prod`
#
# Open Vercel → your project → Settings → Environment Variables.
# Paste each value into the corresponding key. Mark the environment as
# Production (and optionally Preview).
#
# CRITICAL = app will not boot or auth will break without it.
# RECOMMENDED = boot works but a feature stays in mock mode.
# OPTIONAL = nice-to-have.
# ──────────────────────────────────────────────────────────────────────────────


# ════════ CRITICAL — set before first deploy ═════════════════════════════════

# Neon Postgres connection string (use the *pooler* URL, not the direct one)
# neon.tech → your project → Connection Details → "Pooled connection"
DATABASE_URL=

# JWT signing secret. Generate fresh: `openssl rand -base64 32`
AUTH_SECRET=

# OTP hashing secret. Generate fresh: `openssl rand -base64 32`
OTP_HMAC_SECRET=

# Real SMS OTP via MSG91 (you chose: no demo backdoor in prod)
# Get from msg91.com → Settings → Auth Keys + Flows
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=

# Demo OTP code — kept as fallback for local dev only. In prod the
# verify route is gated on NODE_ENV !== 'production', so this is dormant.
OTP_DEMO_CODE=123456


# ════════ RECOMMENDED — turn each "REAL" flag on as you wire the provider ═══

# Razorpay (UPI Intent + Autopay)
PAYMENTS_REAL=false
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
GULLAK_UPI_VPA=gullak@icici
GULLAK_UPI_NAME=Gullak

# Upstash Redis (rate limiting — in prod with missing keys the limiter
# FAILS CLOSED, so OTP / KYC / gold / MF routes will reject. Set this
# or those routes block.)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Digital Gold (SafeGold)
GOLD_REAL=false
SAFEGOLD_API_KEY=
SAFEGOLD_MERCHANT_ID=
SAFEGOLD_BASE_URL=https://app.safegold.com/api/v1

# Mutual Funds (BSE StAR MF)
FUND_REAL=false
BSEMF_CLIENT_CODE=
BSEMF_PASSWORD=
BSEMF_MEMBER_ID=
BSEMF_BASE_URL=https://bsestarmf.in/

# Account Aggregator (Setu AA — Khata Phase 6)
AA_REAL=false
SETU_AA_CLIENT_ID=
SETU_AA_CLIENT_SECRET=
SETU_AA_BASE_URL=https://aa.setu.co/api/v2

# KYC (Setu)
SETU_API_KEY=
SETU_PRODUCT_INSTANCE_ID=

# Cron auth (Vercel injects this automatically when you add a cron in
# vercel.json, but set it explicitly if you want to hit /api/cron/* by hand)
CRON_SECRET=


# ════════ OPTIONAL ══════════════════════════════════════════════════════════

# Sentry error tracking
NEXT_PUBLIC_SENTRY_DSN=

# Feature flags (all default to "true")
FLAGS_ENABLE_ROUNDUP=true
FLAGS_ENABLE_SALARY_SWEEP=true
FLAGS_ENABLE_NOTIFICATIONS=true
FLAGS_ENABLE_UNDO_WINDOW=true
FLAGS_ENABLE_FORCE_FAIL_DEV_TOGGLE=true


# ────────────────────────────────────────────────────────────────────────────
# Notes
# ────────────────────────────────────────────────────────────────────────────
# 1. Without MSG91 keys, real OTP cannot be sent in production — login is dead.
#    Either set MSG91_AUTH_KEY+MSG91_TEMPLATE_ID, or set NODE_ENV=development
#    on a preview deployment to re-enable the demo backdoor (NOT recommended).
#
# 2. Every "REAL" flag stays "false" by default — the seam falls back to the
#    in-process mock. Flip to "true" only after the corresponding provider's
#    keys are populated AND verified.
#
# 3. NEXT_PUBLIC_* variables are bundled into the client. Anything else stays
#    server-only. AUTH_SECRET, OTP_HMAC_SECRET, RAZORPAY_* must NEVER be
#    prefixed with NEXT_PUBLIC_.
