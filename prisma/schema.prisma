// Autopilot India — V1 Prisma schema
// Money is stored in paise (BigInt) everywhere. No floats.
// AuditLog is append-only — no update/delete code paths.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(cuid())
  phone           String   @unique
  name            String?
  locale          String   @default("en") // en | hi | pa | kn
  ageRange        String?
  incomeRange     String?
  state           String?
  salaryDay       Int?
  isSalaried      Boolean  @default(false)
  lifecycleState  String   @default("NEW") // NEW | ONBOARDING | TRUST_ACKNOWLEDGED | GOAL_CREATED | AUTOPILOT_CONFIGURED | MANDATE_PENDING | ACTIVE | PAUSED
  kycCompleted      Boolean  @default(false)
  aaConsentLinkedAt DateTime?
  // KYC fields (Phase 1)
  panLast4          String?  // last 4 chars of PAN — display only, never full PAN
  nomineeName       String?
  nomineeRelation   String?  // self | spouse | parent | child | sibling | other
  nomineeDob        String?  // YYYY-MM-DD string — not DateTime to avoid TZ issues
  // V5 M9 — referral
  referralCode      String?  @unique
  referredBy        String?  // userId of inviter, null for self-signup
  email             String?  // optional; required by some MF providers
  // V5 M11 — push subscriptions stored as JSON array
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  goals             Goal[]
  goalMemberships   GoalMember[]
  rules             AutopilotRule[]
  mandates          Mandate[]
  transactions      Transaction[]
  events            SavingsEvent[]
  auditLogs         AuditLog[]
  streak            Streak?
  notifications     Notification[]
  preferences       UserPreference?
  roundupBucket     RoundupBucket?
  aaConsents        AAConsent[]
  loanOffers        LoanOffer[]
  loanApplications  LoanApplication[]
  referralsMade     Referral[]        @relation("Referrer")
  pushSubscriptions PushSubscription[]
  kycRecords        KYCRecord[]
  consents          UserConsent[]
  holdings          InvestmentHolding[]
  investmentTxns    InvestmentTransaction[]
  mfHoldings        MFHolding[]
  mfTransactions    MFTransaction[]
  riskProfile       RiskProfile?
  grievances        GrievanceTicket[]
}

// V5 M9 — Referral tracking. Real DB rows; reward is a mock ₹100 credit entry.
model Referral {
  id           String   @id @default(cuid())
  referrerUserId String
  referrer     User     @relation("Referrer", fields: [referrerUserId], references: [id], onDelete: Cascade)
  refereePhone String   // referee's phone at signup time (since refereeUserId might not exist yet)
  refereeUserId String? // populated once referee creates account
  code         String   // the invite code that was used
  status       String   @default("PENDING") // PENDING | JOINED | REWARDED
  rewardPaise  BigInt   @default(10000) // ₹100 default
  joinedAt     DateTime?
  rewardedAt   DateTime?
  createdAt    DateTime @default(now())

  @@index([referrerUserId, status])
  @@index([refereeUserId])
}

// V5 M11 — Web Push subscriptions for sending notifications.
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

// V5 M10 — Daily snapshot of city/state-level leaderboards. Refreshed by cron.
model LeaderboardSnapshot {
  id        String   @id @default(cuid())
  periodKey String   // YYYY-MM format
  scope     String   // 'state' | 'city' | 'all'
  scopeKey  String   // e.g., 'KA' for state Karnataka, 'BLR' for city Bangalore, 'all' for global
  rank      Int
  userId    String
  anonName  String   // first letter + initial
  savedPaise BigInt
  munafaPaise BigInt
  createdAt DateTime @default(now())

  @@index([periodKey, scope, scopeKey])
  @@index([userId])
}

// Account Aggregator consent — tracks what the user authorised the AA to fetch.
// V3 is mocked; the surface matches what real Sahamati AA flow would return.
model AAConsent {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fipId          String    // mock FIP identifier (e.g. "MOCK_HDFC")
  consentHandle  String    @unique // mock UUID-shaped handle
  status         String    @default("ACTIVE") // ACTIVE | REVOKED | EXPIRED
  fetchedAt      DateTime?
  expiresAt      DateTime
  payload        String?   // JSON — mock account snapshot (transactions, salary, EMI patterns)
  createdAt      DateTime  @default(now())

  @@index([userId, status])
}

// OCEN — Open Credit Enablement Network. Mocked.
model LoanProduct {
  id             String   @id @default(cuid())
  type           String   @unique // two-wheeler | four-wheeler | gold | consumer-durable | emergency
  name           String
  minAmountPaise BigInt
  maxAmountPaise BigInt
  minTenureDays  Int
  maxTenureDays  Int
  baseRatePctBps Int      // basis points × 100 (e.g., 14% = 1400)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
}

model LoanOffer {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productType    String
  principalPaise BigInt
  tenureDays     Int
  interestPctBps Int
  emiPaise       BigInt
  lenderName     String   // mock NBFC name
  status         String   @default("PRE_APPROVED") // PRE_APPROVED | APPLIED | DISBURSED | EXPIRED | DECLINED
  expiresAt      DateTime
  createdAt      DateTime @default(now())

  applications   LoanApplication[]

  @@index([userId, status])
}

model LoanApplication {
  id             String   @id @default(cuid())
  offerId        String
  offer          LoanOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status         String    @default("SUBMITTED") // SUBMITTED | APPROVED | DISBURSED | REJECTED
  disbursedAt    DateTime?
  idempotencyKey String    @unique
  payload        String    // JSON — application form snapshot
  createdAt      DateTime  @default(now())

  @@index([userId, createdAt])
}

model Goal {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          String // emergency | emi | home | wedding | retirement | festival | education | vehicle
  subType       String?   // 'beti' | 'maa-baap' | 'apna-sapna' (generational sub-template; null for plain goals)
  title         String
  targetPaise   BigInt
  savedPaise    BigInt    @default(0)
  investedPaise BigInt    @default(0)
  growthPaise   BigInt    @default(0)
  deadline      DateTime?
  status        String    @default("active") // active | paused | completed
  isPrimary     Boolean   @default(false)
  // Family Gullak (V5 M1)
  isShared      Boolean   @default(false)
  inviteCode    String?   @unique // short shareable code (e.g., "DOSTI4823"). Null for personal goals.
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  rules        AutopilotRule[]
  transactions Transaction[]
  members      GoalMember[]

  @@index([userId, status])
  @@index([inviteCode])
}

// V5 M1 — Family/Group Gullak. Tracks who's in a shared goal and how much they've put in.
// The Goal.userId remains the original creator (the "owner"). Members reference the same Goal via this join table.
model GoalMember {
  id              String   @id @default(cuid())
  goalId          String
  goal            Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role            String   @default("member") // 'owner' | 'member'
  contributedPaise BigInt   @default(0)
  joinedAt        DateTime @default(now())

  @@unique([goalId, userId])
  @@index([userId])
}

model AutopilotRule {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  goalId      String
  goal        Goal      @relation(fields: [goalId], references: [id], onDelete: Cascade)
  mode        String // fixed | roundup | sweep | inflow_pct
  amountPaise BigInt? // for fixed/sweep
  frequency   String? // daily | weekly (fixed only)
  roundUpTo   Int? // 10 | 50 | 100 (roundup only)
  inflowPct   Int? // basis points: 500 = 5%, 1000 = 10% (inflow_pct only)
  status      String    @default("active") // active | paused | stopped
  pauseUntil  DateTime? // for "Pause for 7 days" / "Pause till salary"
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  mandate      Mandate?
  transactions Transaction[]

  @@index([userId, status])
}

model Mandate {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  ruleId           String    @unique
  rule             AutopilotRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  maxPerDebitPaise BigInt
  cap              String    // daily | weekly | monthly
  // Status lifecycle: PENDING → ACTIVE → HALTED | REVOKED | EXPIRED
  status           String    @default("PENDING") // PENDING | ACTIVE | HALTED | REVOKED | EXPIRED
  // Phase 3 — Razorpay UPI Autopay fields (null in mock mode)
  pspSubscriptionId String?  // Razorpay subscription_id (sub_xxx)
  upiMandateUrn    String?   // NPCI URN returned in subscription.authenticated webhook
  authorisedAt     DateTime  @default(now())
  activatedAt      DateTime? // set when subscription.authenticated webhook fires
  revokedAt        DateTime?

  @@index([userId, status])
}

model Transaction {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  goalId         String?
  goal           Goal?     @relation(fields: [goalId], references: [id], onDelete: SetNull)
  ruleId         String?
  rule           AutopilotRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  source         String    // fixed | roundup | sweep | manual | burst | shagun | withdrawal
  amountPaise    BigInt
  status         String    // pending | success | failed | reversed
  failureReason  String?   // insufficient_balance | mandate_revoked | network_timeout
  // PSP reference fields — null when using mock/simulator, populated by real PSP
  pspRefId       String?   // Razorpay payment_id or equivalent
  pspOrderId     String?   // Razorpay order_id
  pspRawJson     String?   // raw PSP webhook payload for audit/replay
  simulatedRefId String    @default("") // legacy field kept for backwards compat; use pspRefId
  idempotencyKey String    @unique
  reversedAt     DateTime?
  reversalOfId   String?   // points to original txn id
  createdAt      DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([goalId, createdAt])
  @@index([status])
  @@index([pspRefId])
}

// Raw webhook event log — idempotent ingestion from all PSPs.
// Process once, store forever. Never delete — required for reconciliation.
model WebhookEvent {
  id          String    @id @default(cuid())
  provider    String    // razorpay | cashfree | safegold | setu
  eventId     String    @unique // provider's own event/delivery ID
  eventType   String    // payment.captured | mandate.confirmed | etc.
  rawJson     String    // full payload as-received
  processedAt DateTime?
  errorMsg    String?   // set if processing failed
  createdAt   DateTime  @default(now())

  @@index([provider, eventType])
  @@index([createdAt])
}

model SavingsEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  payload   String // JSON
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  eventType String
  payload   String // JSON
  source    String // user | cron | system
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([eventType, createdAt])
}

model Streak {
  id            String    @id @default(cuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentDays   Int       @default(0)
  longestDays   Int       @default(0)
  lastSavedDate DateTime?
  freebiesUsed  Int       @default(0)
  weekKey       String? // YYYY-WW for resetting freebies
  updatedAt     DateTime  @updatedAt
}

model Notification {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   String // actionable | info | milestone
  titleKey   String
  bodyKey    String
  bodyParams String? // JSON
  readAt     DateTime?
  deepLink   String?
  createdAt  DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

model UserPreference {
  userId        String  @id
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  notifySalary  Boolean @default(true)
  notifyRoundup Boolean @default(true)
  notifyWeekly  Boolean @default(true)
  forceFailNext Boolean @default(false)
  updatedAt     DateTime @updatedAt
}

model RoundupBucket {
  userId       String   @id
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dateKey      String // YYYY-MM-DD IST
  pendingPaise BigInt   @default(0)
  items        String   @default("[]") // JSON array of {spend, roundedTo, savePaise}
  updatedAt    DateTime @updatedAt
}

model FeatureFlag {
  key        String   @id
  enabled    Boolean
  rolloutPct Int      @default(100)
  updatedAt  DateTime @updatedAt
}

// OTP challenge for phone-based auth.
// Replaces the hardcoded 123456 accept-all in production.
// One active challenge per phone at a time (previous ones expire naturally).
model OTPChallenge {
  id         String    @id @default(cuid())
  phone      String
  codeHash   String    // HMAC-SHA256 of the OTP — never store plaintext
  attempts   Int       @default(0)
  expiresAt  DateTime
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([phone, expiresAt])
}

// KYC verification audit trail (Phase 1).
// One row per verification attempt. The latest VERIFIED row = user's KYC status.
// Never store full PAN or Aadhaar — only masked references and provider tokens.
model KYCRecord {
  id                    String    @id @default(cuid())
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type                  String    // PAN | AADHAAR | CKYC
  status                String    @default("PENDING") // PENDING | VERIFIED | FAILED | EXPIRED
  provider              String    // setu | idfy | digilocker | manual
  providerRef           String?   // provider's transaction/reference ID
  providerResponseJson  String?   // raw provider response (encrypted at rest via OTP_HMAC_SECRET)
  maskedIdentifier      String?   // e.g. "ABCPX1234X" → "ABCPX****X" for display
  verifiedAt            DateTime?
  expiresAt             DateTime? // some KYCs expire (e.g. video KYC valid 6 months)
  createdAt             DateTime  @default(now())

  @@index([userId, type, status])
}

// DPDP Act 2023 consent log (Phase 1).
// Every consent action — accept or revoke — gets a row. Immutable append-only.
model UserConsent {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  consentType     String   // TERMS | PRIVACY | MANDATE | AA | MARKETING
  documentVersion String   // e.g. "v1.0" — bump when T&C/policy changes
  action          String   @default("ACCEPTED") // ACCEPTED | REVOKED
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime @default(now())

  @@index([userId, consentType])
}

// Phase 4 — Digital Gold (Sona).
// One holding row per user per asset type+provider. Updated on each buy/sell.
// Grams stored as micrograms (×1,000,000) to avoid floats — same BigInt pattern.
model InvestmentHolding {
  id                  String    @id @default(cuid())
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetType           String    // gold | mf_equity | mf_debt | fd
  provider            String    // safegold | kuvera | mock
  // Gold-specific columns (micrograms: 1g = 1_000_000)
  totalMicrograms     BigInt    @default(0)
  avgBuyPaisePerGram  BigInt    @default(0)   // weighted average entry price
  // Generic value tracking
  investedPaise       BigInt    @default(0)
  currentValuePaise   BigInt    @default(0)   // refreshed by price-sync cron
  lastPricedAt        DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  transactions        InvestmentTransaction[]

  @@unique([userId, assetType, provider])
  @@index([userId, assetType])
}

// Every buy/sell of an investment asset. Append-only audit trail.
model InvestmentTransaction {
  id                  String    @id @default(cuid())
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  holdingId           String
  holding             InvestmentHolding @relation(fields: [holdingId], references: [id], onDelete: Cascade)
  assetType           String    // gold | mf_equity | mf_debt
  txnType             String    // buy | sell
  amountPaise         BigInt    // fiat amount deducted (buy) or credited (sell)
  // Gold: grams × 1,000,000
  micrograms          BigInt?
  pricePerGramPaise   BigInt?   // spot price at transaction time
  // PSP / provider fields
  pspRefId            String?   // SafeGold order ID
  pspRawJson          String?   // raw provider response (audit)
  status              String    @default("success") // pending | success | failed
  idempotencyKey      String    @unique
  goalId              String?   // optional goal this purchase is attributed to
  createdAt           DateTime  @default(now())

  @@index([userId, assetType, createdAt])
  @@index([holdingId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Phase 5 — Mutual Funds (Kaagaz)
// ─────────────────────────────────────────────────────────────────────────────

// Curated fund catalog. Seeded + updated daily by the nav-sync cron.
// navPaise stores NAV in paise (₹155.23 → 15523) — BigInt, no floats.
// Units held in micro-units (×1,000,000) across MFHolding and MFTransaction.
model MutualFund {
  id          String   @id @default(cuid())
  schemeCode  String   @unique  // AMFI scheme code (e.g. "122639")
  isin        String?
  schemeName  String
  amcName     String
  // category: index | equity | elss | liquid | hybrid | debt
  category    String
  subCategory String?  // large_cap | mid_cap | flexi_cap | small_cap | etc.
  navPaise    BigInt   @default(0) // latest NAV in paise
  navDate     String?  // YYYY-MM-DD of the above NAV
  minSipPaise      BigInt   @default(50000)  // ₹500 default minimum SIP
  // SEBI Riskometer: low|low_to_moderate|moderate|moderately_high|high|very_high
  riskCategory     String   @default("moderate")
  // Exit load: % × 100 (e.g. 100 = 1%). 0 = no exit load.
  exitLoadPct      Int      @default(0)
  exitLoadDays     Int      @default(0)   // exit load applies within this many days
  // Expense ratio in basis points (e.g. 50 = 0.50%)
  expenseRatioBps  Int      @default(0)
  isCurated        Boolean  @default(false)  // show in Gullak's fund picker
  isActive         Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  holdings     MFHolding[]
  transactions MFTransaction[]

  @@index([category, isCurated])
}

// Per-user per-fund holding. One row; updated on every buy/redeem.
model MFHolding {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  schemeCode        String
  fund              MutualFund @relation(fields: [schemeCode], references: [schemeCode])
  // micro-units: 1 unit = 1_000_000 micro-units (preserves 6 decimal places)
  totalMicroUnits   BigInt   @default(0)
  avgNavPaise       BigInt   @default(0)  // weighted average entry NAV
  investedPaise     BigInt   @default(0)
  currentValuePaise BigInt   @default(0)  // refreshed by nav-sync cron
  lastPricedAt      DateTime?
  folioNumber       String?  // assigned by BSE StAR MF / AMC in real mode
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([userId, schemeCode])
  @@index([userId])
}

// Every purchase/redemption transaction for a mutual fund.
model MFTransaction {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  schemeCode     String
  fund           MutualFund @relation(fields: [schemeCode], references: [schemeCode])
  // buy | redeem | sip_installment
  txnType        String
  amountPaise    BigInt
  // micro-units allotted/redeemed (may be null while status=pending in real mode)
  microUnits     BigInt?
  navPaise       BigInt?  // NAV at time of allotment
  // Order refs
  pspRefId       String?  // BSE order no. / provider ref
  pspRawJson     String?
  // pending → allotted (T+1 in real mode) | failed | reversed
  status         String   @default("allotted")
  idempotencyKey String   @unique
  goalId         String?
  createdAt      DateTime @default(now())

  @@index([userId, schemeCode, createdAt])
}

// ─── Risk Profiling ───────────────────────────────────────────────────────────
// SEBI requires a suitability / risk assessment before recommending MF products.
// One row per user; replaced (not versioned) on retake.
// profile: conservative | moderate | moderately_aggressive | aggressive
model RiskProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Score derived from 5-question questionnaire (max 20)
  score     Int
  // Bucketed label from score
  profile   String   // conservative | moderate | moderately_aggressive | aggressive
  // Raw answers stored for audit
  answers   String   // JSON array of {questionId, answer, points}
  takenAt   DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ─── Reconciliation ───────────────────────────────────────────────────────────
// Tracks daily reconciliation runs across all asset classes.
// One row per scheduled run; filled in by the recon cron job.
model ReconciliationRun {
  id               String    @id @default(cuid())
  runDate          String    // YYYY-MM-DD
  assetClass       String    // gold | mf | upi | all
  totalUsers       Int       @default(0)
  matched          Int       @default(0)  // provider balance == our DB balance
  mismatched       Int       @default(0)
  errors           Int       @default(0)
  // JSON: [{userId, type, ourValuePaise, providerValuePaise}]
  mismatchDetails  String?
  status           String    @default("pending") // pending | running | complete | failed
  startedAt        DateTime  @default(now())
  completedAt      DateTime?

  @@unique([runDate, assetClass])
  @@index([runDate])
}

// ─── Grievance Redressal ──────────────────────────────────────────────────────
// SEBI / RBI mandate a grievance redressal mechanism.
// Tickets must be acknowledged within 3 days and resolved within 30 days.
model GrievanceTicket {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    String    // payment | investment | kyc | account | other
  subject     String
  description String
  // open | acknowledged | in_progress | resolved | closed
  status      String    @default("open")
  // Internal team notes (not shown to user)
  adminNotes  String?
  refId       String?   // linked txnId / orderId if applicable
  acknowledgedAt DateTime?
  resolvedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, status])
  @@index([status, createdAt])
}
