# PRODUCTION env template — copy to Vercel Environment Variables (Settings → Environment Variables)
# DO NOT commit this file with real values.

# ── Database ──────────────────────────────────────────────────
# For Vercel free tier:
#   Option A (recommended): Vercel Postgres — Settings → Storage → Create → Postgres
#   Option B: Neon free tier — neon.tech (returns a postgresql:// URL)
#   Option C: Supabase free tier — supabase.com (use the connection-pool URL with ?pgbouncer=true)
#
# After provisioning, set DATABASE_URL to the postgres URL.
# IMPORTANT: also change `provider = "sqlite"` → `provider = "postgresql"` in prisma/schema.prisma
# Then run `npx prisma migrate dev --name v4_postgres_init` locally to regenerate migrations.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"

# ── Auth ──────────────────────────────────────────────────────
# Generate a strong secret: `openssl rand -base64 32` or any 32+ byte random string
AUTH_SECRET="REPLACE-ME-WITH-32-BYTE-RANDOM-STRING"

# ── OTP demo ──────────────────────────────────────────────────
# For investor demo, keep this so any phone number works with code 123456
OTP_DEMO_CODE="123456"

# ── Feature flags ─────────────────────────────────────────────
FLAGS_ENABLE_ROUNDUP="true"
FLAGS_ENABLE_SALARY_SWEEP="true"
FLAGS_ENABLE_NOTIFICATIONS="true"
FLAGS_ENABLE_UNDO_WINDOW="true"
FLAGS_ENABLE_FORCE_FAIL_DEV_TOGGLE="true"

# ── Cron security ─────────────────────────────────────────────
# Vercel injects this for cron requests — generate any random string
CRON_SECRET="REPLACE-ME-WITH-RANDOM-STRING"

# ── Public site URL (for service worker + canonical) ──────────
NEXT_PUBLIC_SITE_URL="https://your-app.vercel.app"
