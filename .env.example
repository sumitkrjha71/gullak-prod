# Database — get your Neon connection string from neon.tech → your project → Connection Details
DATABASE_URL="postgresql://neondb_owner:<password>@<endpoint>-pooler.<region>.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Auth
AUTH_SECRET="<run: openssl rand -base64 32>"
OTP_DEMO_CODE="123456"

# OTP hardening (Phase 0) — generate a strong random string for production
OTP_HMAC_SECRET="<run: openssl rand -base64 32>"
# MSG91 — required for real OTP SMS in production
MSG91_AUTH_KEY=""
MSG91_TEMPLATE_ID=""

# Sentry — get DSN from sentry.io → your project → Settings → Client Keys
NEXT_PUBLIC_SENTRY_DSN=""

# Razorpay (Phase 2) — get from razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""
PAYMENTS_REAL="false"
GULLAK_UPI_VPA="<your-vpa>@<bank>"
GULLAK_UPI_NAME="Gullak"

# Upstash Redis — get from upstash.com (free tier, no credit card)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Digital Gold — SafeGold (Phase 4) — get from safegold.com/b2b
SAFEGOLD_API_KEY=""
SAFEGOLD_MERCHANT_ID=""
SAFEGOLD_BASE_URL="https://app.safegold.com/api/v1"
GOLD_REAL="false"

# Mutual Funds — BSE StAR MF (Phase 5) — get from bsestarmf.in (enterprise)
BSEMF_CLIENT_CODE=""
BSEMF_PASSWORD=""
BSEMF_MEMBER_ID=""
BSEMF_BASE_URL="https://bsestarmf.in/"
FUND_REAL="false"

# KYC — Setu (get from setu.co → sandbox first)
SETU_API_KEY=""
SETU_PRODUCT_INSTANCE_ID=""

# Feature flags (all default to enabled)
FLAGS_ENABLE_ROUNDUP="true"
FLAGS_ENABLE_SALARY_SWEEP="true"
FLAGS_ENABLE_NOTIFICATIONS="true"
FLAGS_ENABLE_UNDO_WINDOW="true"
FLAGS_ENABLE_FORCE_FAIL_DEV_TOGGLE="true"

# Cron security (Vercel injects this automatically; locally optional)
CRON_SECRET=""
