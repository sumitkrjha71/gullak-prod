# Database
DATABASE_URL="file:./dev.db"

# Auth
AUTH_SECRET="dev-secret-change-me-in-production-please-use-32-bytes"
OTP_DEMO_CODE="123456"

# Feature flags (all default to enabled in V1)
FLAGS_ENABLE_ROUNDUP="true"
FLAGS_ENABLE_SALARY_SWEEP="true"
FLAGS_ENABLE_NOTIFICATIONS="true"
FLAGS_ENABLE_UNDO_WINDOW="true"
FLAGS_ENABLE_FORCE_FAIL_DEV_TOGGLE="true"

# Cron security (Vercel injects this; locally optional)
CRON_SECRET=""
